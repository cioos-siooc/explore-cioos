# Sample environment file for a Coolify-deployed development instance.
#
# Copy this into the Coolify UI -> Application -> Environment Variables, or
# rename to .env.coolify-dev and reference it from the Coolify "Custom .env"
# field. Values shown as <placeholder> must be filled in.
#
# Anything Coolify injects automatically (SERVICE_FQDN_NGINX, SERVICE_URL_NGINX,
# COOLIFY_*, etc.) is intentionally NOT listed here -- do not set those
# manually.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DB_NAME=cde
DB_USER=postgres
DB_PASSWORD=<set-in-coolify>
# Internal docker-compose hostname; do not change unless the db service is renamed.
DB_HOST=db
# Only set DB_HOST_EXTERNAL / DB_EXTERNAL_PORT if you need to reach the db
# from outside the compose network (e.g. running the harvester locally).
# DB_HOST_EXTERNAL=
# DB_EXTERNAL_PORT=5432

# ---------------------------------------------------------------------------
# URLs (auto-derived, do NOT set unless overriding)
# ---------------------------------------------------------------------------
# APP_DOMAIN is auto-derived from Coolify's SERVICE_URL_NGINX (the FQDN you
# attach to the nginx service). Leave commented for normal Coolify deployments.
# APP_DOMAIN=https://dev.example.com
#
# API_URL / BASE_URL are baked into the frontend at build time. The Dockerfile
# defaults to API_URL=/api and BASE_URL=/, which is the right answer for a
# same-origin SPA served behind Coolify's proxy. Override only for unusual
# topologies (separate API host, sub-path mount, etc.).
# API_URL=/api
# BASE_URL=/

# ---------------------------------------------------------------------------
# Redis cache (opt-in)
# ---------------------------------------------------------------------------
# Leave REDIS_HOST/REDIS_URL unset to disable caching entirely so endpoint
# tests always hit fresh data. If you want caching, run a dedicated Redis
# service in this compose stack and set REDIS_HOST to its service name.
# Do NOT use the bare name "redis" -- it will collide with coolify-redis on
# the shared docker network. Use a unique name like "app-redis".
# REDIS_HOST=app-redis
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Application behaviour
# ---------------------------------------------------------------------------
ENVIRONMENT=coolify-dev
# Permissive CORS for dev convenience. Tighten for staging/prod.
CORS_ORIGINS=*
# Swagger UI / OpenAPI endpoint (helpful in dev).
ENABLE_API_DOCS=true
# Disable PDF generation for downloads in dev.
CREATE_PDF=False
# Path inside the scheduler container where downloads are written.
DOWNLOADS_FOLDER=./downloads
# Run the harvester in incremental mode (only new/updated records).
INCREMENTAL_MODE=true

# ---------------------------------------------------------------------------
# Host-side ports
# ---------------------------------------------------------------------------
# Coolify routes traffic via Traefik on 80/443; the published NGINX_PORT only
# matters if you expose the container directly on the VM. 8098 is the
# project's historical default.
NGINX_PORT=8098

# ---------------------------------------------------------------------------
# Observability (optional)
# ---------------------------------------------------------------------------
# SENTRY_DSN=

# ---------------------------------------------------------------------------
# Email (optional, only set if the scheduler should send notifications)
# ---------------------------------------------------------------------------
# GMAIL_USER=
# GMAIL_PASSWORD=

# ---------------------------------------------------------------------------
# Postgres image variant (architecture)
# ---------------------------------------------------------------------------
# Use 'postgis' on x86, 'odidev' on ARM.
DOCKER_POSTGIS_REPO=postgis

# ---------------------------------------------------------------------------
# Compose file selection (Coolify only)
# ---------------------------------------------------------------------------
# Merges docker-compose.coolify.yaml on top of the base compose so the
# `harvester-deploy` service runs once on every deploy. Local dev does NOT
# set this var, so `harvester` stays gated behind `--profile tools`.
COMPOSE_FILE=docker-compose.yaml:docker-compose.coolify.yaml

# ---------------------------------------------------------------------------
# Default Harvest config file
# ---------------------------------------------------------------------------
HARVEST_CONFIG_FILE=harvest_config.sample.yaml