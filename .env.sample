# Harvester, API, Download scheduler
DB_NAME=cde
DB_USER=postgres
DB_PASSWORD=password

# API and scheduler use internal (docker compose) host name
# If the API and DB are both inside docker, this should be 'db'
DB_HOST=db

# host name from outside docker, harvester runs outside docker and connect to the DB directly
DB_HOST_EXTERNAL=db

# API
API_URL=http://localhost:8098/api
BASE_URL=/
REDIS_HOST=redis

# Download scheduler
DOWNLOAD_WAF_URL=http://localhost:8098/downloads
CREATE_PDF=False

# path inside docker
DOWNLOADS_FOLDER=./downloads
# GMAIL_USER=example@example.com
# GMAIL_PASSWORD=password

# For Sentry etc
ENVIRONMENT=development
SENTRY_DSN=

# Use 'postgis' for x86, 'odidev' for ARM
DOCKER_POSTGIS_REPO=postgis
# DOCKER_POSTGIS_REPO=odidev

NGINX_PORT=8098

# CORS configuration for web-api (added in CORS middleware):
# *            => allow all origins (default if unset)
# disabled     => do not enable CORS middleware (no cross-origin browser access)
# comma list   => explicit allow-list, e.g.
#                  CORS_ORIGINS=https://explore.cioos.ca,https://staging.explore.cioos.ca
# NOTE: Requests without an Origin header (curl / server to server) are always allowed when CORS is active.
CORS_ORIGINS=*

# API Documentation configuration:
# true         => enable Swagger UI and OpenAPI docs (default if unset)
# false        => disable API documentation endpoints (/api/docs and /api/openapi.json)
#                 When disabled, requests to these endpoints redirect to BASE_URL
ENABLE_API_DOCS=true

# Host Root for Docker volumes
HOST_ROOT=

# --- Prefect worker / harvest triggers (all optional) ---
# The prefect_worker runs harvest flows IN-PROCESS on a Prefect "process" work
# pool. Scale workers with: docker compose up -d --scale prefect_worker=N
#
# Recurring full-harvest schedule (cron). Unset/empty = no schedule.
HARVESTER_CRON=0 0 */3 * *
# Recurring WoRMS vernaculars backfill schedule (cron). Unset/empty = no schedule.
VERNACULARS_CRON=
# Fire ONE full harvest immediately on each (re)deploy. Off by default so a
# config-only redeploy doesn't kick off a harvest.
RUN_ON_DEPLOY=false
# The primary worker registers the work pool + deployments on startup. Set to
# false ONLY for an extra/remote worker that should just poll (never register).
REGISTER_DEPLOYMENTS=true

# Harvester Mode (true for incremental updates, false for full reload)
INCREMENTAL_MODE=true

# --- Harvest dashboard: per-source trigger + Prefect link ---
# External Prefect UI base URL the browser uses for "View in Prefect" links.
PREFECT_UI_URL=https://prefect-obis.cool.beluga.cioos.ca
# Kill-switch for the dashboard "Trigger harvest" button (the dashboard is
# behind Cloudflare Access). Set true to enable per-source triggering.
HARVEST_TRIGGER_ENABLED=false
# Registered @flow name of the deployable pipeline; per-source deployments live
# under it. Only change if you rename the flow.
HARVEST_FLOW_NAME=CDE Pipeline Run

# Path to harvest config file
HARVEST_CONFIG_FILE=harvest_config.sample.json