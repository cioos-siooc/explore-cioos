# Local development overrides — copy to docker-compose.override.yaml
#   cp docker-compose.override.yaml.sample docker-compose.override.yaml
#
# Compose auto-loads docker-compose.override.yaml on `docker compose up` and
# merges it with docker-compose.yaml. The override file is gitignored so it
# stays local-only and is not deployed to Coolify (which uses the base
# docker-compose.yaml and routes traffic through its own proxy).

services:
  db:
    ports:
      - "${DB_PORT:-5432}:${DB_PORT:-5432}"
  nginx:
    ports:
      - "${NGINX_PORT:-4000}:4000"
  prefect:
    ports:
      - "4200:4200"
