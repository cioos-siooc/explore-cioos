{"id": "7ec89813-61c1-4fa8-8ffb-d2abca7f3b97", "url": "http://ipt.iobis.org/obiscanada/resource?r=nsis_v29_p4_a5_bleakney_meyer", "archive": "https://ipt.iobis.org/obiscanada/archive.do?r=nsis_v29_p4_a5_bleakney_meyer", "published": "2017-03-02T14:54:55.000Z", "created": null, "updated": "2025-11-10T22:43:03.698Z", "core": "occurrence", "extensions": [], "statistics": {"Event": 0, "absence": 0, "dropped": 0, "Occurrence": 25, "DNADerivedData": 0, "MeasurementOrFact": 0}, "extent": "POLYGON((-64.38 45.14,-64.38 45.14,-64.38 45.14,-64.38 45.14,-64.38 45.14))", "title": "NSIS: Observations on salt marsh pools, Minas Basin, Nova Scotia 1965-1977", "citation": "Bleakney, J.S. &amp; Meyer, K.B. (2017) NSIS: Observations on salt marsh pools, Minas Basin, Nova Scotia 1965-1977. Version 1 In OBIS Canada Digital Collections. Bedford Institute of Oceanography, Dartmouth, NS, Canada. Published by OBIS, Digital http://www.iobis.org/. Accessed on \u2013INSERT DATE", "citation_id": null, "abstract": "The principal study area was located along the Habitant Creek estuary southeast of Canning, Kings County, NS in a Spartina patens and S. alterniflora marsh next to the old pilings of Pickett's Wharf.\nHabitant Creek is dyked to the west of the saltmarsh area and fresh water flows out through an aboideau only at low tide, some 6m below the level of the marsh. The marsh extends in width about 250 m from the adjacent roadbed to the creek bank at the wharf pilings. This resource contains a listing of taxa observed in this area.", "intellectualrights": "This work is licensed under a  Creative Commons Attribution (CC-BY) 4.0 License", "feed": {"id": "6ae5ad4f-2a01-43bd-9fb4-cc9c7f38f105", "url": "http://ipt.vliz.be/obiscanada/rss.do"}, "institutes": [{"name": "Fisheries and Oceans Canada \u2013 Bedford Institute of Oceanography", "oceanexpert_id": 5070, "oceanexpert_parent_id": 19196}], "contacts": [{"role": null, "type": "creator", "givenname": null, "surname": "OBIS Canada", "organization