{"id": "f9822123-91ba-4f3b-a87d-369a7d073b05", "url": "http://ipt.iobis.org/obiscanada/resource?r=biochem_sameoto_frb282", "archive": "https://ipt.iobis.org/obiscanada/archive.do?r=biochem_sameoto_frb282", "published": "2021-04-16T11:07:34.000Z", "created": null, "updated": "2025-11-09T22:09:30.051Z", "core": "occurrence", "extensions": [], "statistics": {"Event": 0, "absence": 0, "dropped": 0, "Occurrence": 4614, "DNADerivedData": 0, "MeasurementOrFact": 0}, "extent": "POLYGON((-63.65 44.62,-63.55 44.62,-63.55 44.7,-63.65 44.7,-63.65 44.62))", "title": "BioChem: Macrozooplankton biomass measurements in Bedford Basin, 1969-1971", "citation": "Sameoto, D.D., 2013. BioChem: Macrozooplankton biomass measurements in Bedford Basin, 1969-1971. Version 1 In OBIS Canada Digital Collections. Bedford Institute of Oceanography, Dartmouth, NS, Canada. Published by OBIS, Digital http://www.iobis.org/. Accessed on \u2013INSERT DATE", "citation_id": "http://iobis.org/mapper/?resource_id=xxx", "abstract": "This dataset contains occurrence records associated with a study describing the seasonal changes in biomass and species composition of the major groups of macrozooplankton of Bedford Basin, an area polluted with domestic sewage. Sagitta elegans Verrill was the dominant species in both numbers and biomass of predatory macrozooplankton.\n\nAbundance information (numbers per cubic metre) and biomass (grams per cubic metre) are provided.", "intellectualrights": "This work is licensed under a  Creative Commons Attribution (CC-BY) 4.0 License", "feed": {"id": "6ae5ad4f-2a01-43bd-9fb4-cc9c7f38f105", "url": "http://ipt.vliz.be/obiscanada/rss.do"}, "institutes": [{"name": "Fisheries and Oceans Canada \u2013 Bedford Institute of Oceanography", "oceanexpert_id": 5070, "oceanexpert_parent_id": 19196}], "contacts": [{"role": null, "type": "creator", "givenname": "Mary", "surname": "Kennedy", "organization": "Fisheries and Oceans Canada", "position": "Data manager", "email": "mary.kennedy@dfo-