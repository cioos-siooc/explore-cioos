# These values could also come in via docker compose file, that would have priority
DB_NAME=cde
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
REDIS_HOST=localhost

# Disable cache layer entirely when set to 1 (otherwise leave 0)
CACHE_DISABLED=0
# Default cache TTL in seconds (e.g. 300 = 5 minutes)
CACHE_TTL_SECONDS=300

# Port the Express app will bind to inside the container / host
PORT=5000
