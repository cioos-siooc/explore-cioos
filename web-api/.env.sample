# These values could also come in via docker compose file, that would have priority
DB_NAME=cde
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
REDIS_HOST=localhost

# CORS configuration:
# *            => allow all origins
# disabled     => disable CORS middleware entirely
# comma list   => allow only those origins (no spaces):
#                  CORS_ORIGINS=https://explore.cioos.ca,https://staging.explore.cioos.ca
CORS_ORIGINS=*
